{
  "name": "notebook-lm-clone",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "NotebookLM-inspired research workspace with Claude-backed grounded chat and Studio outputs.",
  "scripts": {
    "dev": "NODE_ENV=development node server/index.js",
    "serve": "NODE_ENV=production node server/index.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint .",
    "audit:buttons": "node scripts/button-audit.js",
    "verify": "npm run audit:buttons && npm run build && npm run lint && node --check server/index.js",
    "smoke:api": "node scripts/smoke-api.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.3",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^0.544.0",
    "vite": "^7.1.7",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.44.1"
  }
}
