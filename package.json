{
  "name": "sourcestudio-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Source-grounded AI research workbench with ingestion, Evidence Packs, Citation Ledgers, and Studio artifacts.",
  "scripts": {
    "dev": "NODE_ENV=development node server/index.js",
    "serve": "NODE_ENV=production node server/index.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint .",
    "seed": "node scripts/seed.js",
    "test": "node --test tests/*.test.js",
    "audit:buttons": "node scripts/button-audit.js",
    "verify": "npm run audit:buttons && npm run build && npm run lint && npm test && node --check server/index.js",
    "smoke:api": "node scripts/smoke-api.js",
    "smoke:e2e": "node scripts/e2e-smoke.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.3",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.544.0",
    "pg": "^8.22.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "unpdf": "^1.6.2",
    "vite": "^7.1.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.44.1"
  }
}
