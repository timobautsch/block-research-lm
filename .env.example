# Server
PORT=5173

# Claude / Anthropic
# Required for real LLM-backed chat, source discovery, and Studio generation.
ANTHROPIC_API_KEY=replace-with-your-anthropic-key

# Optional. Defaults to claude-haiku-4-5-20251001.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional local convenience for reusing existing private Blockresearch env files.
# Colon-separated absolute paths. Do not commit .env.local or secret-bearing files.
# BLOCKRESEARCH_ENV_PATHS=/absolute/path/to/blockresearch/.env.dev:/absolute/path/to/seo-automation/.env
