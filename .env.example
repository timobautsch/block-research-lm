# SourceStudio AI local server
PORT=5173

# Model providers stay server-side. The local deterministic fallback works without keys.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_ARTIFACT_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ARTIFACT_MODEL=
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash
GOOGLE_ARTIFACT_MODEL=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_ID_HOST_A=
ELEVENLABS_VOICE_ID_HOST_B=
ELEVENLABS_MODEL=eleven_v3
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
COHERE_API_KEY=

# Provider routing hints. Use "auto" to select the first configured server-side
# provider, or force "local", "anthropic", "openai", or "google".
DEFAULT_REASONING_PROVIDER=auto
DEFAULT_ARTIFACT_PROVIDER=local
SOURCESTUDIO_ARTIFACT_PROVIDER=
SOURCESTUDIO_AUDIO_SCRIPT_PROVIDER=
DEFAULT_EMBEDDING_PROVIDER=deterministic-local

# Retrieval. Hybrid search works locally; set COHERE_API_KEY to enable the
# external reranker after BM25/vector candidate retrieval.
RERANK_PROVIDER=auto
COHERE_RERANK_MODEL=rerank-v4.0-pro
COHERE_RERANK_MAX_TOKENS_PER_DOC=1200
RERANK_CANDIDATE_LIMIT=40
RERANK_WEIGHT=0.68

# Optional production infrastructure. The interview demo uses local JSON/filesystem storage.
DATABASE_URL=
REDIS_URL=
STORAGE_DIR=.data/sourcestudio

# YouTube ingestion egress. YouTube bot-checks datacenter IPs (Cloud Run), so a
# rotating RESIDENTIAL proxy is required in production (e.g. Webshare:
# http://USER-rotate:PASS@p.webshare.io:80). Applies to yt-dlp AND the direct
# caption fetch fallbacks. Leave empty locally.
YTDLP_PROXY=
# Optional alternative: Netscape cookies.txt from a logged-in YouTube session,
# either base64-encoded inline or as a file path (e.g. a secret mount). Cookies
# expire unpredictably and carry account-restriction risk; prefer YTDLP_PROXY.
YTDLP_COOKIES_B64=
YTDLP_COOKIES_FILE=
